# App
APP_NAME="KPersonal Finance Tracker API"
ENVIRONMENT="development"
DEBUG=true
API_STR="/api"

# Security
SECRET_KEY="your-secret-key-here-change-in-production-2024"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS - Simple comma-separated list
BACKEND_CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000", "http://127.0.0.1:5173"]
# Firebase (temporary placeholders)
FIREBASE_CREDENTIALS_PATH="./firebase-credentials.json"
FIREBASE_STORAGE_BUCKET="your-project-id.appspot.com"
FIREBASE_PROJECT_ID="your-project-id"

# Plaid (leave empty for now)
PLAID_CLIENT_ID=""
PLAID_SECRET=""
PLAID_ENV="sandbox"

# File Upload
MAX_UPLOAD_SIZE=10485760
ALLOWED_EXTENSIONS=[".csv"]